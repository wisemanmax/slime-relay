# ── Copy this to `.env` and fill in. `.env` is gitignored — never commit it. ──

# Shared secret. MUST match the relay's RELAY_TOKEN and the SlimeWatch app's token.
SLIME_TOKEN=change-me

# Port the extractor listens on.
PORT=8787

# ── Relay registration (optional but recommended) ──
# Your deployed SlimeRelay URL, e.g. https://slime-relay.<your-subdomain>.workers.dev
# Leave blank to run standalone (no dashboard registration).
RELAY_URL=

# How the Apple TV / dashboard should reach THIS machine, e.g.
#   http://10.0.0.14:8787         (LAN)
#   http://100.x.x.x:8787         (NordVPN Meshnet / Tailscale IP)
# If blank, the server auto-detects its first LAN IPv4.
PUBLIC_ADDRESS=

# Friendly name shown on the dashboard (defaults to the machine hostname).
SERVER_NAME=

# ── Optional extras ──
# Local direct-resolver (TMDB-Embed-API) for the no-browser fast path.
DIRECT_RESOLVER=
# Subtitle fetching key (leave blank to disable).
SLIME_SUBS_KEY=
