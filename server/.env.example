# ── Prefer  `node setup.js`  — it writes this file for you and validates it. ──
# Or copy this to `.env` and fill it in by hand. `.env` is gitignored; never commit it.

# Shared secret. MUST be identical to the relay's USER_TOKEN and the SlimeWatch
# app's token. Generate one with:  openssl rand -hex 20
SLIME_TOKEN=change-me

# Port the extractor listens on.
PORT=8787

# ── Relay registration (optional but recommended) ──
# Your deployed SlimeRelay URL, e.g. https://slime-relay.<your-subdomain>.workers.dev
# Leave blank to run standalone (no dashboard registration).
RELAY_URL=

# How the Apple TV / dashboard reaches THIS machine, e.g.
#   http://10.0.0.14:8787         (same-home LAN)
#   http://100.x.x.x:8787         (Tailscale IP - use this for a cross-home fleet)
# Leave blank to auto-detect (prefers a Tailscale IP when present). On Windows
# especially, if the app can't reach this box, pin the right IP here -
# `node doctor.js` prints the candidates.
PUBLIC_ADDRESS=

# Friendly name shown on the dashboard (defaults to the machine hostname).
SERVER_NAME=

# ── Optional extras ──
# Local direct-resolver (TMDB-Embed-API) for the no-browser fast path.
DIRECT_RESOLVER=
# Subtitle fetching key (leave blank — Wyzie subtitles work with no key).
SLIME_SUBS_KEY=
